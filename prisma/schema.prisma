generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  language  String   @default("english") // english or french
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  groups    Group[]
}

model Group {
  id         String   @id @default(cuid())
  name       String
  level      String   // beginner, intermediate, advanced
  language   String   @default("english") // english or french
  schedule   String?  // e.g. "Mon, Wed, Fri - 10:00 AM"
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  students   Student[]
  payments   Payment[]
}

model Student {
  id        String   @id @default(cuid())
  name      String
  age       Int
  phone     String?
  email     String?
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  payments  Payment[]
}

model Payment {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  amount     Int      // in DH
  month      String   // e.g. "2025-01" (YYYY-MM format)
  status     String   @default("paid") // paid, pending, overdue
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([studentId, groupId, month])
}
